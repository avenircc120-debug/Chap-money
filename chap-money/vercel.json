{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-spec run codegen && pnpm --filter @workspace/chap-money run build",
  "outputDirectory": "artifacts/chap-money/dist/public",
  "framework": null,
  "rewrites": [
    {
      "destination": "/api/handler",
      "source": "/api/(.*)"
    },
    {
      "destination": "/index.html",
      "source": "/(.*)"
    }
  ]
}
